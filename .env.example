# Shell
NEXT_PUBLIC_PLATFORM_SHELL_NAME="Open Micro Platform"
NEXT_PUBLIC_MICRO_APP_ERROR_ENDPOINT="/api/micro-app-errors"
MICRO_APP_REGISTRY_REVALIDATE_SECONDS=60
MICRO_APP_LOCAL_APPS_ENABLED=true

# Local dev entrypoints use Vite source files.
NEXT_PUBLIC_CUSTOMER_APP_ORIGIN="http://127.0.0.1:5173"
NEXT_PUBLIC_BILLING_APP_ORIGIN="http://127.0.0.1:5174"
NEXT_PUBLIC_ANALYTICS_APP_ORIGIN="http://127.0.0.1:5175"
NEXT_PUBLIC_ADMIN_APP_ORIGIN="http://127.0.0.1:5176"
NEXT_PUBLIC_AI_ASSISTANT_APP_ORIGIN="http://127.0.0.1:5177"
NEXT_PUBLIC_VUE_COMMERCE_APP_ORIGIN="http://127.0.0.1:5178"
NEXT_PUBLIC_ANGULAR_OPS_APP_ORIGIN="http://127.0.0.1:5179"
NEXT_PUBLIC_DESIGN_SYSTEM_APP_ORIGIN="http://127.0.0.1:5180"

# Production/static remote entrypoints should point at built ESM files.
# NEXT_PUBLIC_CUSTOMER_APP_ENTRY_PATH="/customer-app.js"
# NEXT_PUBLIC_BILLING_APP_ENTRY_PATH="/billing-app.js"
# NEXT_PUBLIC_ANALYTICS_APP_ENTRY_PATH="/analytics-app.js"
# NEXT_PUBLIC_ADMIN_APP_ENTRY_PATH="/admin-app.js"
# NEXT_PUBLIC_AI_ASSISTANT_APP_ENTRY_PATH="/ai-assistant-app.js"
# NEXT_PUBLIC_VUE_COMMERCE_APP_ENTRY_PATH="/vue-commerce-app.js"
# NEXT_PUBLIC_ANGULAR_OPS_APP_ENTRY_PATH="/angular-ops-app.js"
# NEXT_PUBLIC_DESIGN_SYSTEM_APP_ENTRY_PATH="/design-system-app.js"
# NEXT_PUBLIC_CUSTOMER_APP_STYLE_PATH="/customer-app.css"
# NEXT_PUBLIC_BILLING_APP_STYLE_PATH="/billing-app.css"
# NEXT_PUBLIC_ANALYTICS_APP_STYLE_PATH="/analytics-app.css"
# NEXT_PUBLIC_ADMIN_APP_STYLE_PATH="/admin-app.css"
# NEXT_PUBLIC_AI_ASSISTANT_APP_STYLE_PATH="/ai-assistant-app.css"
# NEXT_PUBLIC_VUE_COMMERCE_APP_STYLE_PATH="/vue-commerce-app.css"
# NEXT_PUBLIC_ANGULAR_OPS_APP_STYLE_PATH="/angular-ops-app.css"
# NEXT_PUBLIC_DESIGN_SYSTEM_APP_STYLE_PATH="/design-system-app.css"

# Optional remote registry service.
# MICRO_APP_REGISTRY_URL="https://registry.example.com/apps.json"

# MCP Apps remote server for ChatGPT / Claude / compliant AI hosts.
MCP_APPS_SERVER_PORT=8787
MCP_APPS_PATH="/mcp"
MCP_APPS_ENABLED="ai-assistant"
MCP_APPS_HOST_PROFILE="portable"
PUBLIC_SHELL_ORIGIN="http://127.0.0.1:3001"
PUBLIC_MCP_ORIGIN="https://ai-assistant.manojmukherjee.co.in"
PUBLIC_APP_BASE_DOMAIN="manojmukherjee.co.in"
PUBLIC_APP_PROTOCOL="https"

# Optional per-app public origin/resource overrides.
# MCP_APP_AI_ASSISTANT_PUBLIC_ORIGIN="https://ai-assistant.manojmukherjee.co.in"
# MCP_APP_AI_ASSISTANT_RESOURCE_URL="http://127.0.0.1:3001/api/mcp/apps/ai-assistant/resource"
# Optional host-approved standard MCP UI sandbox domain override.
# Keep unset for the universal /mcp endpoint. It omits ui.domain for Claude and emits openai/widgetDomain for ChatGPT.
# /mcp/openai and /mcp/chatgpt still emit standard ui.domain as the app public origin.
# MCP_APP_AI_ASSISTANT_UI_DOMAIN=""
# MCP_APP_AI_ASSISTANT_UI_DOMAIN_MODE="portable"
