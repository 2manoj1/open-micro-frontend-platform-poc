{
  "name": "@openmf/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Framework-neutral micro frontend runtime SDK for shell and self-deployable micro apps",
  "keywords": [
    "micro-frontend",
    "micro-frontends",
    "web-components",
    "nextjs",
    "rsc",
    "mcp",
    "mcpapps",
    "event-bus",
    "module-federation-alternative",
    "frontend-platform"
  ],
  "author": "Manoj Mukherjee",
  "license": "MIT",
  "homepage": "https://github.com/2manoj1/open-micro-frontend-platform-poc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2manoj1/open-micro-frontend-platform-poc.git",
    "directory": "packages/platform-sdk"
  },
  "bugs": {
    "url": "https://github.com/2manoj1/open-micro-frontend-platform-poc/issues"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pack:dry": "pnpm pack --dry-run",
    "prepack": "pnpm run clean && pnpm run build && pnpm run lint",
    "validate": "pnpm run lint && pnpm run build && pnpm run pack:dry"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./event-bus": {
      "types": "./dist/event-bus.d.ts",
      "import": "./dist/event-bus.js"
    },
    "./html-fragment": {
      "types": "./dist/html-fragment.d.ts",
      "import": "./dist/html-fragment.js"
    },
    "./mcp-app": {
      "types": "./dist/mcp-app.d.ts",
      "import": "./dist/mcp-app.js"
    },
    "./mcp-standard": {
      "types": "./dist/mcp-standard.d.ts",
      "import": "./dist/mcp-standard.js"
    },
    "./micro-app": {
      "types": "./dist/micro-app.d.ts",
      "import": "./dist/micro-app.js"
    },
    "./observability": {
      "types": "./dist/observability.d.ts",
      "import": "./dist/observability.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./runtime-state": {
      "types": "./dist/runtime-state.d.ts",
      "import": "./dist/runtime-state.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    },
    "./web-mcp": {
      "types": "./dist/web-mcp.d.ts",
      "import": "./dist/web-mcp.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
